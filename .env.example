# AILens360 — environment configuration.
# Copy to .env and adjust. Anything left unset falls back to the built-in default.
# All values are parsed by internal/config/loader.go.

# ─── Public origins (used by the api to advertise the proxy URL) ─────────────
# Shared default for both processes — set this when proxy and api live behind
# the same reverse-proxy host. Must start with http:// or https://.
# Example: https://ailens.example.com
AILENS360_PUBLIC_URL=
# Override for the proxy specifically (split-domain deployment).
# Falls back to AILENS360_PUBLIC_URL above when empty.
# Example: https://ailens-proxy.example.com
# AILENS360_PROXY_PUBLIC_URL=

# ─── Proxy (LLM-facing listener) ─────────────────────────────────────────────
AILENS360_PROXY_ADDR=0.0.0.0:8080
AILENS360_PROXY_READ_TIMEOUT=60s
# 0 = unlimited; SSE streams may live long.
AILENS360_PROXY_WRITE_TIMEOUT=0s
AILENS360_PROXY_IDLE_TIMEOUT=120s
# 10 MiB
AILENS360_PROXY_MAX_REQUEST_BODY=10485760
AILENS360_PROXY_UPSTREAM_TIMEOUT=5m
# In-memory snapshot cap for request body + parser preview of response body.
# Streamed responses bypass this on the wire; this only bounds RAM on the hot path.
# 8 MiB
AILENS360_PROXY_RAW_BODY_LIMIT=8388608
# (Moved up — AILENS360_PROXY_PUBLIC_URL is now in the "Public origins" section.)

# ─── API (console) ───────────────────────────────────────────────────────────
AILENS360_API_ADDR=0.0.0.0:8081
# Comma-separated.
AILENS360_API_CORS_ORIGINS=http://localhost:5173

# ─── Collector (stream consumer) ─────────────────────────────────────────────
AILENS360_COLLECTOR_HEALTH_ADDR=0.0.0.0:8082

# ─── Postgres (required) ─────────────────────────────────────────────────────
AILENS360_DB_DSN=postgres://ailens:ailens@localhost:5432/ailens360?sslmode=disable
AILENS360_DB_MAX_CONNS=20
AILENS360_DB_MAX_IDLE_CONNS=5

# ─── Redis (required) ────────────────────────────────────────────────────────
AILENS360_REDIS_ADDR=localhost:6379
AILENS360_REDIS_PASSWORD=
AILENS360_REDIS_DB=0

# ─── Cache (L1 in-process / L2 Redis) ────────────────────────────────────────
AILENS360_CACHE_L1_CAP=10000
AILENS360_CACHE_L1_TTL=30s
AILENS360_CACHE_L2_TTL=10m

# ─── Realtime metrics ────────────────────────────────────────────────────────
AILENS360_METRICS_WINDOW_SECS=60
AILENS360_METRICS_RETENTION_SECS=7200

# ─── Logging ─────────────────────────────────────────────────────────────────
# level: debug | info | warn | error
AILENS360_LOG_LEVEL=info
# format: text | json
AILENS360_LOG_FORMAT=text

# ─── Body store (S3 / MinIO, required) ───────────────────────────────────────
AILENS360_BODY_STORE_ENDPOINT=localhost:9000
AILENS360_BODY_STORE_BUCKET=ailens360-traces
AILENS360_BODY_STORE_REGION=us-east-1
AILENS360_BODY_STORE_ACCESS_KEY_ID=minioadmin
AILENS360_BODY_STORE_SECRET_ACCESS_KEY=minioadmin
AILENS360_BODY_STORE_USE_SSL=false
# MinIO requires path style. AWS S3 supports either.
AILENS360_BODY_STORE_PATH_STYLE=true
# S3 multipart minimum is 5 MiB.
AILENS360_BODY_STORE_PART_SIZE=5242880
AILENS360_BODY_STORE_GZIP_BODIES=true
AILENS360_BODY_STORE_UPLOAD_TIMEOUT=30s
# How the api hands trace bodies to the browser:
#   false (default) — api streams bytes from MinIO through itself.
#                     MinIO can stay private; single hostname; api eats the bandwidth.
#   true            — api returns a 302 to a short-lived presigned MinIO URL.
#                     MinIO must be browser-reachable + CORS-configured. Fastest path.
AILENS360_BODY_STORE_PRESIGN_REDIRECT=false
AILENS360_BODY_STORE_PRESIGN_TTL=15m
# Optional override used only when generating presigned URLs (PRESIGN_REDIRECT=true)
# — set this when the browser reaches MinIO via a different hostname than the server.
AILENS360_BODY_STORE_PUBLIC_ENDPOINT=

# ─── Redis Stream (proxy → collector IPC) ────────────────────────────────────
AILENS360_STREAM_KEY=ailens360:traces
AILENS360_STREAM_CONSUMER_GROUP=collector
AILENS360_STREAM_BLOCK_TIMEOUT=5s
AILENS360_STREAM_BATCH_SIZE=200
# Messages stuck in PEL longer than this are XCLAIM'd by another consumer.
AILENS360_STREAM_PENDING_IDLE_MAX=60s
AILENS360_STREAM_CLAIM_INTERVAL=30s

# ─── Trace table partitioning (collector maintainer) ─────────────────────────
# How many future months to pre-create (1 = next month).
AILENS360_PARTITION_PRE_CREATE=1
# Default 3. Hard-deletes data older than N months: DROPs traces_YYYYMM
# partitions and removes MinIO objects under "{project_id}/{YYYYMM}/" for
# those months. Set a negative value (e.g. -1) to disable purging.
AILENS360_PARTITION_RETENTION_MONTHS=3
AILENS360_PARTITION_CHECK_INTERVAL=24h

# ─── Pricing catalog ─────────────────────────────────────────────────────────
AILENS360_PRICING_SOURCE_URL=https://models.dev/api.json
AILENS360_PRICING_REFRESH_INTERVAL=12h
AILENS360_PRICING_DISABLE=false

# ─── Auth ────────────────────────────────────────────────────────────────────
AILENS360_AUTH_USERNAME=admin
AILENS360_AUTH_PASSWORD=admin
# REQUIRED for the api process. Generate with: openssl rand -hex 32
# Empty value fails validation; sessions must survive across replicas.
AILENS360_JWT_SECRET=
AILENS360_AUTH_TOKEN_TTL=168h
