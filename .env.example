# AILens360 — environment configuration.
# Copy to .env and adjust. Anything left unset falls back to the built-in default.
# All values are parsed by internal/config/loader.go.

# ─── Proxy (LLM-facing listener) ─────────────────────────────────────────────
AILENS360_PROXY_ADDR=0.0.0.0:8080
AILENS360_PROXY_READ_TIMEOUT=60s
# 0 = unlimited; SSE streams may live long.
AILENS360_PROXY_WRITE_TIMEOUT=0s
AILENS360_PROXY_IDLE_TIMEOUT=120s
# 10 MiB
AILENS360_PROXY_MAX_REQUEST_BODY=10485760
AILENS360_PROXY_UPSTREAM_TIMEOUT=5m
# External origin used to build the proxy_prefix shown in the UI.
# Leave empty to derive from the inbound request. Must start with http:// or https://.
# Example: https://ailens.example.com
AILENS360_PROXY_PUBLIC_URL=

# ─── API (console) ───────────────────────────────────────────────────────────
# If empty, falls back to the proxy listener.
AILENS360_API_ADDR=0.0.0.0:8080
# Comma-separated.
AILENS360_API_CORS_ORIGINS=http://localhost:5173

# ─── Postgres (required) ─────────────────────────────────────────────────────
AILENS360_DB_DSN=postgres://ailens:ailens@localhost:5432/ailens360?sslmode=disable
AILENS360_DB_MAX_CONNS=20
AILENS360_DB_MAX_IDLE_CONNS=5

# ─── Redis (required) ────────────────────────────────────────────────────────
AILENS360_REDIS_ADDR=localhost:6379
AILENS360_REDIS_PASSWORD=
AILENS360_REDIS_DB=0

# ─── Cache (L1 in-process / L2 Redis) ────────────────────────────────────────
AILENS360_CACHE_L1_CAP=10000
AILENS360_CACHE_L1_TTL=30s
AILENS360_CACHE_L2_TTL=10m

# ─── Realtime metrics ────────────────────────────────────────────────────────
AILENS360_METRICS_WINDOW_SECS=60
AILENS360_METRICS_RETENTION_SECS=7200

# ─── Logging ─────────────────────────────────────────────────────────────────
# level: debug | info | warn | error
AILENS360_LOG_LEVEL=info
# format: text | json
AILENS360_LOG_FORMAT=text

# ─── Trace collector ─────────────────────────────────────────────────────────
AILENS360_COLLECTOR_BUFFER_SIZE=10000
AILENS360_COLLECTOR_BATCH_SIZE=200
AILENS360_COLLECTOR_FLUSH_INTERVAL=1s
# 256 KiB
AILENS360_COLLECTOR_RAW_BODY_LIMIT=262144

# ─── Pricing catalog ─────────────────────────────────────────────────────────
AILENS360_PRICING_SOURCE_URL=https://models.dev/api.json
AILENS360_PRICING_REFRESH_INTERVAL=12h
AILENS360_PRICING_DISABLE=false

# ─── Auth ────────────────────────────────────────────────────────────────────
AILENS360_AUTH_USERNAME=admin
AILENS360_AUTH_PASSWORD=admin
# REQUIRED. Generate with: openssl rand -hex 32
# Empty value fails validation; sessions must survive across replicas.
AILENS360_JWT_SECRET=
AILENS360_AUTH_TOKEN_TTL=168h
